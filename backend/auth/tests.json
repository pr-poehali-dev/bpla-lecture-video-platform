{
  "tests": [
    {
      "name": "Register duplicate user returns error",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "test_drone_999@example.com", "password": "test1234", "name": "Test User 999", "callsign": "Сокол-999"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Email уже зарегистрирован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password returns 401",
      "method": "POST",
      "path": "/?action=login",
      "body": {"callsign": "Сокол-999", "password": "wrongpassword"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    }
  ]
}