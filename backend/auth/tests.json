{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "test_drone_777@example.com", "password": "test1234", "name": "Test User"},
      "expectedStatus": 201,
      "expectedBody": {"message": "Заявка отправлена. Ожидайте одобрения администратора."},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login pending user",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "test_drone_777@example.com", "password": "test1234"},
      "expectedStatus": 403,
      "expectedBody": {"error": "pending"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    }
  ]
}