{
  "tests": [
    {
      "name": "Register missing fields returns error",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "", "password": "", "name": "", "callsign": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Заполните все поля"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password returns 401",
      "method": "POST",
      "path": "/?action=login",
      "body": {"callsign": "Сокол-999", "password": "wrongpassword"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    }
  ]
}